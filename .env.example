# ─── Apple Music API ────────────────────────────────────────────────
# Required for fetching via the Apple Music API.
# Not needed if you use --from-xml to import an iTunes Library export.

# 1. Apple Developer Token (JWT)
#    Create at: https://developer.apple.com/account/resources/authkeys/list
#    - Click "+" → Key Name: apple-mp3, enable "Media Services (MusicKit)"
#    - Download the .p8 private key file
#    - Generate JWT: https://developer.apple.com/documentation/applemusicapi/generating_developer_tokens
#    - Or use: https://github.com/nickvdyck/apple-music-token-generator
APPLE_DEVELOPER_TOKEN=

# 2. Music User Token
#    Required for accessing your personal library.
#    Easiest way to get it: open https://music.apple.com in a browser,
#    open DevTools → Network tab, play any song, filter by "api.music.apple.com",
#    copy the "Music-User-Token" request header value.
#    It expires periodically — re-fetch if you get 401 errors.
APPLE_MUSIC_USER_TOKEN=

# ─── YouTube ─────────────────────────────────────────────────────────
# Optional: YouTube Data API v3 key for more reliable search.
# Without this, the tool scrapes YouTube search results.
# Get one at: https://console.cloud.google.com → APIs → YouTube Data API v3
YOUTUBE_API_KEY=

# ─── Pipeline defaults (optional) ────────────────────────────────────
# OUTPUT_DIR=output
# DOWNLOADS_DIR=downloads
